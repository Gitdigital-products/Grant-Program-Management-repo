scripts/validate-application.js

`javascript
// scripts/validate-application.js
// Validates all application JSON files against application.schema.json

const fs = require('fs');
const path = require('path');
const Ajv = require('ajv');

const ajv = new Ajv();
const schema = JSON.parse(fs.readFileSync('data/schemas/application.schema.json', 'utf8'));
const validate = ajv.compile(schema);

const dir = 'data/applications/';
const files = fs.readdirSync(dir).filter(f => f.endsWith('.json'));

let errors = [];

files.forEach(file => {
  const data = JSON.parse(fs.readFileSync(path.join(dir, file), 'utf8'));
  const valid = validate(data);

  if (!valid) {
    errors.push({ file, errors: validate.errors });
  }
});

if (errors.length > 0) {
  console.error('Validation failed:', JSON.stringify(errors, null, 2));
  process.exit(1);
}

console.log('All applications validated successfully.');
`

