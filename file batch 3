scripts/assign-reviewers.js

`javascript
// scripts/assign-reviewers.js
// Automatically assigns reviewers to applications

const fs = require('fs');

const applications = fs.readdirSync('data/applications').filter(f => f.endsWith('.json'));
const reviewers = JSON.parse(fs.readFileSync('data/reviewers.json', 'utf8'));

let assignments = {};

applications.forEach((file, index) => {
  const appId = file.replace('.json', '');
  const reviewer = reviewers[index % reviewers.length];

  assignments[appId] = reviewer;
});

fs.writeFileSync('data/reviewer-assignments.json', JSON.stringify(assignments, null, 2));
console.log('Reviewer assignments generated.');
`

