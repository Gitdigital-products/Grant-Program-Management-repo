scripts/generate-transparency-report.js

`javascript
// scripts/generate-transparency-report.js
// Generates transparency.md from aggregated scores + approvals

const fs = require('fs');

const scores = JSON.parse(fs.readFileSync('data/aggregated-scores.json', 'utf8'));
const approvals = fs.existsSync('data/approvals.json')
  ? JSON.parse(fs.readFileSync('data/approvals.json', 'utf8'))
  : {};

let md = `---
title: Transparency Report
layout: default
---

Transparency Report

This report lists all approved grants, their scores, and funding amounts.

| ID | Title | Score | Funding | Summary |
|----|-------|--------|---------|---------|
`;

Object.keys(approvals).forEach(id => {
  const a = approvals[id];
  const s = scores[id] || {};

  md += | ${id} | ${a.title} | ${s.total || 'N/A'} | $${a.funding} | ${a.summary} |\n;
});

fs.writeFileSync('pages/transparency.md', md);
console.log('Transparency report updated.');
`

