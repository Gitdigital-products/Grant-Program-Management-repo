scripts/aggregate-scores.js

`javascript
// scripts/aggregate-scores.js
// Aggregates reviewer scores and outputs final results

const fs = require('fs');
const path = require('path');

const scoresDir = 'data/scores/';
const outputFile = 'data/aggregated-scores.json';

const files = fs.existsSync(scoresDir)
  ? fs.readdirSync(scoresDir).filter(f => f.endsWith('.json'))
  : [];

let aggregated = {};

files.forEach(file => {
  const score = JSON.parse(fs.readFileSync(path.join(scoresDir, file), 'utf8'));
  const id = score.application_id;

  if (!aggregated[id]) {
    aggregated[id] = { impact: [], feasibility: [], innovation: [] };
  }

  aggregated[id].impact.push(score.scores.impact);
  aggregated[id].feasibility.push(score.scores.feasibility);
  aggregated[id].innovation.push(score.scores.innovation);
});

let results = {};

Object.keys(aggregated).forEach(id => {
  const s = aggregated[id];
  results[id] = {
    impact: average(s.impact),
    feasibility: average(s.feasibility),
    innovation: average(s.innovation),
    total: average(s.impact) + average(s.feasibility) + average(s.innovation)
  };
});

function average(arr) {
  return arr.reduce((a, b) => a + b, 0) / arr.length;
}

fs.writeFileSync(outputFile, JSON.stringify(results, null, 2));
console.log('Aggregated scores written to', outputFile);
`

