.github/workflows/update-tracker.yml

```yaml
name: Update Tracker Page

on:
  push:
    paths:
      - 'data/master_tracker.csv'
      - 'data/applications/*.json'
  schedule:
    - cron: '0 */6 * * *' # Run every 6 hours

jobs:
  update-tracker:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install dependencies
        run: npm ci # if you have a package.json; otherwise skip

      - name: Generate tracker markdown
        run: node scripts/generate-tracker.js
        # This script should read master_tracker.csv and produce pages/tracker.md

      - name: Commit changes
        run: |
          git config --global user.name 'github-actions[bot]'
          git config --global user.email 'github-actions[bot]@users.noreply.github.com'
          git add pages/tracker.md
          git diff --quiet && git diff --staged --quiet || git commit -m "Automated tracker update"
          git push
```

You'll also need a scripts/generate-tracker.js script. Here's a simple version:

```javascript
// scripts/generate-tracker.js
const fs = require('fs');
const csv = require('csv-parser'); // You'll need to npm install csv-parser

const inputFile = 'data/master_tracker.csv';
const outputFile = 'pages/tracker.md';
const results = [];

fs.createReadStream(inputFile)
  .pipe(csv())
  .on('data', (data) => results.push(data))
  .on('end', () => {
    let markdown = `---
title: Application Tracker
layout: default
---

# Track Your Application

Enter your application ID to see status:

<form>
  <input type="text" placeholder="APP-2025-001" />
  <button>Check Status</button>
</form>

## Recent Submissions
| ID | Title | Status | Submitted |
|----|-------|--------|-----------|
`;

    results.slice(0, 10).forEach(row => {
      markdown += `| ${row.ID} | ${row.Title} | ${row.Status} | ${row.Submitted} |\n`;
    });

    fs.writeFileSync(outputFile, markdown);
    console.log('Tracker updated');
  });
```

